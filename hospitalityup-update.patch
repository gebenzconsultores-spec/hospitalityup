+            </div>
+
+            {/* Plan + Moneda */}
+            <div className="grid grid-cols-2 gap-4">
+              <div className="space-y-2">
+                <Label>{t.plan}</Label>
+                <Select
+                  value={formData.plan}
+                  onValueChange={value => setFormData(prev => ({ ...prev, plan: value }))}
