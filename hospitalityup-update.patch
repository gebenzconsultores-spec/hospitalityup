+                      <Trash2 className="size-3" />
+                      {tc.eliminar}
+                    </Button>
+                  </div>
+                </CardContent>
+              </Card>
+            )
+          })}
+        </div>
+      )}
+
+      {/* Create / Edit Dialog */}
